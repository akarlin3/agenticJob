# Copy this file to `.env` and fill in any keys you have:
#
#   cp .env.example .env
#
# Every value is optional. With keys blank, the pipeline falls back to mock
# mode and the web app still boots — so `docker compose up` works out of the
# box even before you add credentials.

# Google Gemini — ingestion + evaluator agents
GEMINI_API_KEY=

# Anthropic Claude — tailor + coach agents
ANTHROPIC_API_KEY=

# Optional live job-search providers (searcher). Mock listings are used if unset.
JSEARCH_API_KEY=
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
